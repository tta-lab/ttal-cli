---
// Typer — cycles through words with a typing/deleting animation
// Usage: <Typer words={["Telegram", "Teamwork", "Taskwarrior"]} />
interface Props {
  words: string[];
  prefix?: string;
  suffix?: string;
}

const { words, prefix = 'The ', suffix = ' Agentic Lab' } = Astro.props;
---

<span class="typer-container">
  <span class="typer-prefix">{prefix}</span><span class="typer-word" data-words={JSON.stringify(words)}></span><span class="typer-cursor">|</span><span class="typer-suffix">{suffix}</span>
</span>

<script>
  class Typer {
    el: HTMLElement;
    words: string[];
    wordIndex = 0;
    charIndex = 0;
    isDeleting = false;

    constructor(el: HTMLElement) {
      this.el = el;
      this.words = JSON.parse(el.dataset.words || '[]');
      if (this.words.length > 0) {
        this.tick();
      }
    }

    tick() {
      if (!this.el.isConnected) return; // stop if removed from DOM
      const current = this.words[this.wordIndex];

      if (this.isDeleting) {
        this.charIndex--;
      } else {
        this.charIndex++;
      }

      this.el.textContent = current.substring(0, this.charIndex);

      let delay = this.isDeleting ? 50 : 100;

      if (!this.isDeleting && this.charIndex === current.length) {
        delay = 2000; // pause at full word
        this.isDeleting = true;
      } else if (this.isDeleting && this.charIndex === 0) {
        this.isDeleting = false;
        this.wordIndex = (this.wordIndex + 1) % this.words.length;
        delay = 400; // pause before next word
      }

      setTimeout(() => this.tick(), delay);
    }
  }

  document.querySelectorAll('.typer-word').forEach(el => {
    new Typer(el as HTMLElement);
  });
</script>

<style>
  .typer-container {
    display: inline;
  }

  .typer-cursor {
    animation: blink 1s step-end infinite;
    color: var(--sl-color-accent);
    font-weight: 300;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
