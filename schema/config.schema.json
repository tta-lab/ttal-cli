{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ttal.guion.io/schema/config.schema.json",
  "properties": {
    "shell": {
      "type": "string",
      "enum": [
        "zsh",
        "fish"
      ],
      "description": "Shell for spawning workers"
    },
    "sync": {
      "properties": {
        "subagents_paths": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Directories for subagent definitions"
        },
        "skills_paths": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Directories for skill definitions"
        },
        "commands_paths": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Directories for command definitions"
        },
        "rules_paths": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Directories for RULE.md files"
        },
        "global_prompt_path": {
          "type": "string",
          "description": "Path to global CLAUDE.md prompt"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Paths for subagent and skill deployment"
    },
    "ask": {
      "properties": {
        "references_path": {
          "type": "string",
          "description": "Local path for cloned OSS reference repos (default: ~/.ttal/references/)"
        },
        "model": {
          "type": "string",
          "description": "Model for the ask subagent (default: claude-sonnet-4-6)"
        },
        "max_steps": {
          "type": "integer",
          "description": "Maximum agent steps (default: 100)"
        },
        "max_tokens": {
          "type": "integer",
          "description": "Maximum output tokens per step (default: 131072)"
        },
        "output": {
          "type": "string",
          "enum": [
            "verbose",
            "quiet"
          ],
          "description": "Output verbosity for human CLI use: \"verbose\" (default) or \"quiet\""
        },
        "agent_output": {
          "type": "string",
          "enum": [
            "verbose",
            "quiet"
          ],
          "description": "Output verbosity for agent sessions (TTAL_AGENT_NAME set).\nDefault is quiet. Set to \"verbose\" to see streaming in agent sessions."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Ask subcommand settings"
    },
    "flicknote": {
      "properties": {
        "inline_projects": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Project substrings to inline (default: plan)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Flicknote integration settings"
    },
    "voice": {
      "properties": {
        "vocabulary": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Custom vocabulary words for Whisper"
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 language code (default: en)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Global voice settings (vocabulary, language)"
    },
    "default_team": {
      "type": "string",
      "description": "Active team — falls back to \"default\" if unset"
    },
    "teams": {
      "additionalProperties": {
        "properties": {
          "frontend": {
            "type": "string",
            "enum": [
              "telegram",
              "matrix"
            ],
            "description": "Messaging frontend for this team (\"telegram\" or \"matrix\"; default: \"telegram\")"
          },
          "team_path": {
            "type": "string",
            "description": "Root path for agent workspaces. Agent path = team_path/agent_name"
          },
          "data_dir": {
            "type": "string",
            "description": "ttal data directory (default: ~/.ttal/\u003cteam\u003e)"
          },
          "taskrc": {
            "type": "string",
            "description": "Taskwarrior config file path (default: \u003cdata_dir\u003e/taskrc)"
          },
          "chat_id": {
            "type": "string",
            "description": "Telegram chat ID for this team"
          },
          "lifecycle_agent": {
            "type": "string",
            "description": "Deprecated: use notification_token_env instead"
          },
          "notification_token_env": {
            "type": "string",
            "description": "Override env var for notification bot token (default: {UPPER_TEAM}_NOTIFICATION_BOT_TOKEN)"
          },
          "agent_runtime": {
            "type": "string",
            "enum": [
              "claude-code"
            ],
            "description": "Runtime for agent sessions"
          },
          "worker_runtime": {
            "type": "string",
            "enum": [
              "claude-code",
              "codex"
            ],
            "description": "Runtime for spawned workers"
          },
          "agent_model": {
            "type": "string",
            "enum": [
              "haiku",
              "sonnet",
              "opus"
            ],
            "description": "Model for agent sessions (default: sonnet)"
          },
          "worker_model": {
            "type": "string",
            "enum": [
              "haiku",
              "sonnet",
              "opus"
            ],
            "description": "Model for spawned workers (default: sonnet; +hard tag overrides to opus)"
          },
          "reviewer_runtime": {
            "type": "string",
            "enum": [
              "claude-code",
              "codex"
            ],
            "description": "Runtime for spawned reviewers (falls back to worker_runtime)"
          },
          "reviewer_model": {
            "type": "string",
            "enum": [
              "haiku",
              "sonnet",
              "opus"
            ],
            "description": "Model for spawned reviewers (falls back to worker_model)"
          },
          "merge_mode": {
            "type": "string",
            "enum": [
              "auto",
              "manual"
            ],
            "description": "PR merge mode override for this team"
          },
          "comment_sync": {
            "type": "string",
            "enum": [
              "none",
              "pr"
            ],
            "description": "Comment sync mode: \"none\" (DB only) or \"pr\" (mirror to PR). Default: \"pr\".",
            "default": "pr"
          },
          "voice_language": {
            "type": "string",
            "description": "ISO 639-1 language code for Whisper (default: en; auto for auto-detect)"
          },
          "agents": {
            "additionalProperties": {
              "properties": {},
              "additionalProperties": false,
              "type": "object",
              "description": "AgentConfig is deprecated."
            },
            "type": "object",
            "description": "Per-agent credentials for this team"
          },
          "voice_vocabulary": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "Custom vocabulary words for Whisper transcription accuracy"
          },
          "emoji_reactions": {
            "type": "boolean",
            "description": "Enable emoji reactions on Telegram tool messages",
            "default": false
          },
          "task_sync_url": {
            "type": "string",
            "description": "TaskChampion sync server URL for ttal doctor --fix"
          },
          "user": {
            "properties": {
              "name": {
                "type": "string",
                "description": "Human's display name (e.g. \"neil\"). Falls back to $USER env var if empty."
              }
            },
            "additionalProperties": false,
            "type": "object",
            "description": "Optional per-team human identity override (falls back to global [user])"
          },
          "matrix": {
            "properties": {
              "homeserver": {
                "type": "string",
                "description": "Matrix homeserver URL (e.g. \"https://matrix.example.com\")"
              },
              "notification_room": {
                "type": "string",
                "description": "Room ID for system notifications"
              },
              "notification_token_env": {
                "type": "string",
                "description": "Env var name for notification bot access token"
              },
              "human_user_id": {
                "type": "string",
                "description": "Matrix user ID of the human owner, invited to all provisioned rooms (e.g. \"@neil:ttal.dev\")"
              },
              "agents": {
                "additionalProperties": {
                  "properties": {
                    "access_token_env": {
                      "type": "string",
                      "description": "Env var name for this agent's Matrix access token"
                    },
                    "room_id": {
                      "type": "string",
                      "description": "Matrix room ID for this agent's chat (e.g. \"!abc:example.com\")"
                    }
                  },
                  "additionalProperties": false,
                  "type": "object",
                  "description": "MatrixAgentConfig holds per-agent Matrix credentials."
                },
                "type": "object",
                "description": "Per-agent Matrix credentials"
              }
            },
            "additionalProperties": false,
            "type": "object",
            "description": "Matrix-specific configuration (only used when frontend = \"matrix\")"
          },
          "breathe_threshold": {
            "type": "number",
            "description": "Context usage threshold (%) below which auto-breathe is skipped (default: 40).\nUse a pointer so that an explicit 0 (always breathe) is not silently promoted to 40."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "description": "TeamConfig holds per-team configuration."
      },
      "type": "object",
      "description": "Per-team configuration sections"
    },
    "user": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Human's display name (e.g. \"neil\"). Falls back to $USER env var if empty."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Human user identity (used by GUI ChatService and message queries)"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "title": "ttal CLI configuration",
  "description": "Configuration file for ttal CLI (~/.config/ttal/config.toml)"
}
